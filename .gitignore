__pycache__/
*.pyc
.env
.venv/
venv/
.pytest_cache/
.DS_Store
# Local-only abstracts and raw payloads are kept out of the repo for IP hygiene.
# The public site lives in docs/ and is committed; drafts/archive are local reading.
data/drafts/*.json
data/archive/*.md
!data/drafts/.gitkeep
!data/archive/.gitkeep
.claude/
